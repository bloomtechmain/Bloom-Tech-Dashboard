# ── Server ────────────────────────────────────────────────────────────────────
PORT=5001
NODE_ENV=production
JWT_SECRET=replace_with_a_long_random_secret

# ── Database ──────────────────────────────────────────────────────────────────
# Railway PostgreSQL plugin sets DATABASE_URL automatically.
# Leave this blank locally and use the individual vars below instead.
DATABASE_URL=

# Individual vars for local development (ignored when DATABASE_URL is set)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=bloomaudit
DB_PASSWORD=your_password_here
DB_PORT=5432
